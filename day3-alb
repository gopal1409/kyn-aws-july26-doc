#before we create the lb we need to create a saprate sg create a new file e1.sg-alb.tf
  resource "aws_security_group" "alb_sg" {
    name = "alb-sg-gopal"
    description = "allow http traffic to alb"
    vpc_id = aws_vpc.my_vpc.id 

    ingress {
        description = "HTTP"
        from_port = 80
        to_port = 80
        protocol = "tcp"
        cidr_blocks = ["0.0.0.0/0"]
    }
    ingress {
        description = "HTTPS"
        from_port = 443
        to_port = 443
        protocol = "tcp"
        cidr_blocks = ["0.0.0.0/0"]
    }

    egress {
        from_port = 0
        to_port = 0
        protocol = "-1"
        cidr_blocks = ["0.0.0.0/0"]
        ipv6_cidr_blocks = [ "::/0" ]
    }
    tags = merge(local.project_tags,
    {
      Name = "web-gopal-lb"
    }
  )
}

#lets add the alb e2.alb.tf
resource "aws_alb" "web-lb" {
  name               = "gopal-web-lb"
  internal           = false
  load_balancer_type = "application"
  security_groups    = [aws_security_group.alb_sg.id]
  #select the subnet
  subnets = [for subnet in aws_subnet.web_subnet : subnet.id]
  tags = merge(local.project_tags,
    {
      Name = "web-gopal-lb"
  })
}

output "alb_dns_name" {
  value = aws_alb.web-lb.dns_name
}

##lets add the targetgroup e3.tg.tf
resource "aws_lb_target_group" "web_tg" {
    name = "gopal-web-tg"
    port = 80
    protocol = "HTTP"
    vpc_id = aws_vpc.my_vpc.id 
    health_check {
      enabled = true 
      healthy_threshold = 3
      unhealthy_threshold = 2
      interval = 30
      timeout = 4
      path = "/"
      protocol = "HTTP"
      matcher = "200" #if it dont return the request 200 that instance need to be unhealthy
    }
     tags = merge(local.project_tags,
    {
      Name = "web-gopal-lb"
  })
}
