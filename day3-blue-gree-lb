#lets create green instance
  ##inside the app folder create a new sh script give the filename as appgreen.sh
#!/bin/bash
apt-get update -y
apt-get install -y unzip wget curl git
apt-get install -y apache2
systemctl enable apache2
systemctl start apache2
echo "welcome to my website $(hostname) green" > /var/www/html/index.html
  #######create a new file d5.green-instance.tf
  resource "aws_instance" "green" {
  for_each                    = aws_subnet.web_subnet
  ami                         = data.aws_ami.ubuntu.id
  instance_type               = "t3.micro"
  subnet_id                   = each.value.id
  vpc_security_group_ids      = [aws_security_group.web_sg.id]
  key_name                    = aws_key_pair.aws_key.key_name
  associate_public_ip_address = true
  user_data                   = file("${path.module}/app/appgreen.sh") #this sh script need to match with your green sh script
  tags = merge(local.project_tags,
    {
      Name = "web-gopal-green${each.key}"
    }
  )

}

#and in the output 
  output "public_ips_blue" {
  value = [for instance in aws_instance.web : instance.public_ip]
}

output "public_ips_green" {
  value = [for instance in aws_instance.green : instance.public_ip]
}
##then copy one of the public green instance ip 
  welcome to my website ip-10-0-1-42 green
##lets create the target group green e5.tg-green.tf
resource "aws_lb_target_group" "green_tg" {
  name     = "gopal-web-green-tg"
  port     = 80
  protocol = "HTTP"
  vpc_id   = aws_vpc.my_vpc.id
  health_check {
    enabled             = true
    healthy_threshold   = 3
    unhealthy_threshold = 2
    interval            = 30
    timeout             = 4
    path                = "/"
    protocol            = "HTTP"
    matcher             = "200" #if it dont return the request 200 that instance need to be unhealthy
  }
  tags = merge(local.project_tags,
    {
      Name = "web-gopal-lb"
  })
}

##once we create the target group we need to attach this instance to the target group e5.green-target.tf
#as we have created all the instance using for_each loop 
#in the target group attachment we need to register all the instance using for_each
resource "aws_lb_target_group_attachment" "green_targets" {
  for_each         = aws_instance.green
  target_group_arn = aws_lb_target_group.green_tg.arn
  target_id        = each.value.id
  port             = 80
}
##3finally we need to divert traffic to the listener modify the listener
resource "aws_lb_listener" "http" {
  load_balancer_arn = aws_alb.web-lb.arn
  port = 80
  protocol = "HTTP"
  default_action {
    type = "forward"
    #forward the request to target group
   forward {
     target_group {
       arn = aws_lb_target_group.web_tg.arn 
       weight = 50
     }
     target_group {
       arn = aws_lb_target_group.green_tg.arn 
       weight = 50
     }
   }
  }
}
