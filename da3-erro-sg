systemctl enable apache2
systemctl start apache2
echo "welcome to my website $(hostname)" > /var/www/html/index.html

  ##also verify the vm for the path of app.sh file 
  resource "aws_instance" "web" {
  for_each                    = aws_subnet.web_subnet
  ami                         = data.aws_ami.ubuntu.id
  instance_type               = "t3.medium"
  subnet_id                   = each.value.id
  vpc_security_group_ids      = [aws_security_group.web_sg.id]
  key_name                    = aws_key_pair.aws_key.key_name
  associate_public_ip_address = true
  user_data                   = file("${path.module}/app/app.sh")
  tags = merge(local.project_tags,
    {
      Name = "web-gopal-${each.key}"
    }
  )

}
##replace the data block with this
data "aws_ami" "ubuntu" {
  most_recent = true
  owners      = ["099720109477"]
  filter {
    name   = "name"
    values = ["ubuntu/images/hvm-ssd*/ubuntu-*-amd64-server-*"]
  }
  filter {
    name   = "architecture"
    values = ["x86_64"]
  }
  filter {
    name   = "root-device-type"
    values = ["ebs"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
  filter {
    name   = "state"
    values = ["available"]
  }
}

