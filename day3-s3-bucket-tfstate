#on your desktop create a new folder then open new visual studio editor select the folder 
  #inside the folder create a file called as provider.tf #inside required provider we are providing random generator plugin 
  terraform {
  required_providers {
    aws = { #this is the name of the cloud service provider
      source  = "hashicorp/aws"
      version = "~> 6.0" #it is important for production
    }
    random = {
        source = "hashicorp/random"
        version = "~> 3.7"
    }
  }
 
}

# Configure the AWS Provider
provider "aws" {
  region = "us-east-1" #this will ensure that all resources are created in the specified AWS region
  #this is the subscription id for your AWS account
}

#this provider block is divded into two parts
//
/* close */

  ##lets create the random.tf file which will generate a random pet name
  resource "random_pet" "bucket_name" {
    length = 2
    separator = "-"
    #happy-otter
    #blue-lion
    #tiny-wolf
}

##finally create a new file s3.tf
  resource "aws_s3_bucket" "tfstate" {
  bucket = "gopal-tfstate-${random_pet.bucket_name.id}"
  
  #enable versioning
  
  tags = {
    Name = "terraform tfstate for gopal"
  }
}

output "bucket_name" {
  description = "name of the bucket"
  value = aws_s3_bucket.tfstate.bucket
}

output "bucket_arn" {
  description = "name of the bucket"
  value = aws_s3_bucket.tfstate.arn
}
resource "aws_s3_bucket_versioning" "versioning" {
  bucket = aws_s3_bucket.tfstate.id
  versioning_configuration {
    status = "Enabled"
  }
}
