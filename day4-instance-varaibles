variable "blue_instances" {
  type = map(object({
    subnet = string
    instance_type = string
  }))
}

#change the d4.vm.tf
  resource "aws_instance" "web" {
  for_each                    = var.blue_instances #i loop around using subnet
  ami                         = data.aws_ami.ubuntu.id
  subnet_id                   = aws_subnet.web_subnet[each.value.subnet].id
  instance_type               = each.value.instance_type #we provide set of values using terraform object instance type and az
  #instance_type = var.instance_type_blue #this will used for string

  vpc_security_group_ids      = [aws_security_group.web_sg.id]
  key_name                    = aws_key_pair.aws_key.key_name
  associate_public_ip_address = true
  user_data                   = file("${path.module}/app/app.sh")
  tags = merge(local.project_tags,
    {
      Name = "web-gopal-${each.key}"
    }
  )

}

